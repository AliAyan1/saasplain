# ============================================
# Plainbot – Environment variables
# Copy to .env.local and set values. Never commit .env.local.
# ============================================

# ---------- Required for app to run ----------
# Database (use MYSQL_URL for single connection string, or DB_* for separate vars)
MYSQL_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"
# Or:
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=ecommerce_support

# Auth (required in production, min 16 chars). Use a single line, no leading/trailing spaces or newlines.
AUTH_SECRET="your-random-secret-min-32-chars"

# App URL (for emails, redirects, Stripe success URL). No trailing slash.
NEXT_PUBLIC_APP_URL="https://plainbot.io"

# ---------- OpenAI (chat) ----------
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# ---------- Resend (emails: welcome, limit-reached, forwarded) ----------
RESEND_API_KEY="re_..."
EMAIL_FROM="hello@plainbot.io"

# ---------- Stripe (checkout & webhooks) ----------
STRIPE_SECRET_KEY="sk_live_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Monthly subscription price IDs from Stripe Dashboard (Products → Prices), format price_...
STRIPE_PRICE_ID_GROWTH_MONTHLY="price_..."
STRIPE_PRICE_ID_PRO_MONTHLY="price_..."
STRIPE_PRICE_ID_AGENCY_MONTHLY="price_..."

# ---------- Optional ----------
# Homepage founding-offer countdown (ISO 8601). Defaults to 2026-04-26 end of day UTC if unset.
# NEXT_PUBLIC_FOUNDING_OFFER_END="2026-04-26T23:59:59.000Z"

# Dashboard “Need a custom plan? Talk to us” → Calendly (defaults in code if unset)
# NEXT_PUBLIC_CALENDLY_URL="https://calendly.com/your-org"

# Cron for 24h upgrade reminders (if you use it)
# CRON_SECRET=your-secret

# Pinecone (optional – RAG / knowledge)
# PINECONE_API_KEY=...
# PINECONE_INDEX_NAME=...
# PINECONE_ENVIRONMENT=us-east-1

# Google Calendar (optional – schedule demo)
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# GOOGLE_REFRESH_TOKEN=...
# GOOGLE_CALENDAR_ID=primary
# GOOGLE_CALENDAR_TIMEZONE=UTC
